{
  "name": "fukashi",
  "version": "0.2.0",
  "description": "A deterministic masonry layout engine with a thin React virtualization adapter.",
  "type": "module",
  "license": "MIT",
  "sideEffects": false,
  "repository": {
    "type": "git",
    "url": "git+https://github.com/iitai-dev/Fukashi.git"
  },
  "bugs": {
    "url": "https://github.com/iitai-dev/Fukashi/issues"
  },
  "homepage": "https://github.com/iitai-dev/Fukashi#readme",
  "engines": {
    "node": ">=20"
  },
  "keywords": [
    "masonry",
    "react",
    "virtualization",
    "grid",
    "layout"
  ],
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    }
  },
  "files": [
    "dist",
    "README.md",
    "docs/public",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsup src/index.ts --format esm,cjs --dts --sourcemap --clean",
    "test": "vitest run",
    "test:stress": "vitest run test/stress",
    "test:browser": "node scripts/build-browser-stress.mjs && playwright test",
    "bench": "vitest bench",
    "typecheck": "tsc --noEmit",
    "check": "npm run typecheck && npm run test && npm run build",
    "check:package": "npm run build && publint run --strict --pack npm && attw --pack .",
    "verify": "npm run check && npm run check:package && npm audit --omit=dev",
    "verify:full": "npm run verify && npm run test:browser",
    "prepublishOnly": "npm run verify"
  },
  "peerDependencies": {
    "react": ">=18.0.0",
    "react-dom": ">=18.0.0"
  },
  "overrides": {
    "esbuild": "$esbuild"
  },
  "devDependencies": {
    "@arethetypeswrong/cli": "^0.18.3",
    "@playwright/test": "^1.61.0",
    "@types/node": "^26.0.0",
    "@types/react": "^18.3.23",
    "@types/react-dom": "^18.3.7",
    "esbuild": "^0.28.1",
    "jsdom": "^24.1.3",
    "publint": "^0.3.21",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "tsup": "^8.5.0",
    "typescript": "^5.9.3",
    "vitest": "^4.1.9"
  }
}
